# Reverse proxy for both hosts, with automatic HTTPS (Caddy requests and
# renews Let's Encrypt certificates on its own - no certbot, no manual
# renewal cron). Replace both domains below with your real ones; Caddy
# needs them to resolve to this server's IP before it can issue a cert.
#
# See docs/DEPLOY.md for the full setup this plugs into.

app.beritabot.com {
	reverse_proxy web:3100
}

api.beritabot.com {
	# Publicly-readable media objects (MinIO) served under the API host at
	# this one path, rather than a fourth DNS record - avoids needing
	# another subdomain just to expose the object storage bucket.
	handle /ainews-media/* {
		reverse_proxy minio:9000
	}
	handle {
		reverse_proxy api:4000
	}
}
