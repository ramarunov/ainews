# AI News CMS — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME="AI News CMS"
APP_VERSION=1.0.0
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
PORT=4000
FRONTEND_PORT=3000

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://ainews:strongpassword@localhost:5432/ainews_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ainews_db
DATABASE_USER=ainews
DATABASE_PASSWORD=strongpassword
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# ─── OpenSearch / Elasticsearch ──────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_INDEX_PREFIX=ainews

# ─── JWT & Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-secret-at-least-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-secret
BCRYPT_ROUNDS=12

# ─── OAuth Providers ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── MFA ─────────────────────────────────────────────────────────────────────
MFA_APP_NAME="AI News CMS"
MFA_ISSUER="ainews"

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-session-secret
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ─── S3-Compatible Object Storage ────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=ainews-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/ainews-media
CDN_URL=

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@ainews.local
EMAIL_FROM_NAME="AI News CMS"

# ─── AI Providers ────────────────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Google Gemini
GOOGLE_AI_API_KEY=
GOOGLE_AI_DEFAULT_MODEL=gemini-1.5-pro

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1

# Active AI Provider (openai | google | anthropic | openrouter | ollama)
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=anthropic

# ─── News APIs ───────────────────────────────────────────────────────────────
NEWSAPI_KEY=
GNEWS_API_KEY=
MEDIASTACK_KEY=
BING_NEWS_KEY=

# ─── RSS & Feed Processing ───────────────────────────────────────────────────
RSS_FETCH_INTERVAL_MINUTES=15
RSS_MAX_ITEMS_PER_FEED=50
RSS_TIMEOUT_MS=10000

# ─── Queue (BullMQ) ──────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY_MS=5000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AI_MAX_REQUESTS=20

# ─── Security ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change-this-32-char-encryption-key!!
CORS_ORIGINS=http://localhost:3000
CSRF_SECRET=change-this-csrf-secret
HELMET_CSP=true

# ─── Monitoring & Logging ────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty
SENTRY_DSN=
PROMETHEUS_PORT=9090

# ─── Webhooks ────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-this-webhook-secret
WEBHOOK_TIMEOUT_MS=5000

# ─── Feature Flags ───────────────────────────────────────────────────────────
FEATURE_AI_ENABLED=true
FEATURE_COMMENTS_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_NEWS_INTELLIGENCE=true
FEATURE_GEO_ENGINE=true
FEATURE_PLUGIN_SYSTEM=true
