{
    "name": "@ainews/api",
    "version": "1.0.0",
    "private": true,
    "description": "AI News CMS — NestJS Backend API",
    "scripts": {
        "build": "nest build",
        "dev": "nest start --watch",
        "debug": "nest start --debug --watch",
        "start": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "test:integration": "jest --config ./test/jest-integration.json --runInBand",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:seed": "ts-node prisma/seed.ts",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate",
        "db:backup": "ts-node -r tsconfig-paths/register scripts/backup-db.ts",
        "db:restore": "ts-node -r tsconfig-paths/register scripts/restore-db.ts",
        "backfill:embeddings": "ts-node -r tsconfig-paths/register scripts/backfill-embeddings.ts",
        "seed:subcategories": "ts-node -r tsconfig-paths/register scripts/seed-subcategories.ts",
        "backfill:article-schema": "ts-node -r tsconfig-paths/register scripts/backfill-article-schema.ts",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.24.1",
        "@aws-sdk/client-s3": "^3.577.0",
        "@aws-sdk/s3-request-presigner": "^3.577.0",
        "@google/generative-ai": "^0.15.0",
        "@mozilla/readability": "^0.6.0",
        "@nestjs/bull": "^10.1.1",
        "@nestjs/cache-manager": "^2.2.2",
        "@nestjs/common": "^10.3.0",
        "@nestjs/config": "^3.2.0",
        "@nestjs/core": "^10.3.0",
        "@nestjs/event-emitter": "^2.0.4",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.3.0",
        "@nestjs/schedule": "^4.0.1",
        "@nestjs/swagger": "^7.3.0",
        "@nestjs/throttler": "^5.1.2",
        "@opensearch-project/opensearch": "^2.7.0",
        "@prisma/client": "^5.14.0",
        "@sentry/node": "^10.65.0",
        "axios": "^1.7.2",
        "bcrypt": "^5.1.1",
        "bull": "^4.12.9",
        "bullmq": "^5.7.0",
        "cache-manager": "^5.4.0",
        "cache-manager-redis-yet": "^5.1.3",
        "cheerio": "^1.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "compression": "^1.7.4",
        "date-fns": "^3.6.0",
        "file-type": "16.5.4",
        "handlebars": "^4.7.8",
        "helmet": "^7.1.0",
        "ioredis": "^5.3.2",
        "isomorphic-dompurify": "^2.14.0",
        "joi": "^17.13.0",
        "jsdom": "^24.1.0",
        "multer": "^1.4.5-lts.1",
        "nanoid": "^5.0.7",
        "nest-winston": "^1.9.7",
        "nodemailer": "^6.9.13",
        "openai": "^4.47.0",
        "otplib": "^12.0.1",
        "passport": "^0.7.0",
        "passport-github2": "^0.1.12",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "prom-client": "^15.1.3",
        "qrcode": "^1.5.4",
        "reflect-metadata": "^0.2.2",
        "rss-parser": "^3.13.0",
        "rxjs": "^7.8.1",
        "sharp": "^0.33.4",
        "slugify": "^1.6.6",
        "uuid": "^9.0.1",
        "winston": "^3.13.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.3.2",
        "@nestjs/schematics": "^10.1.1",
        "@nestjs/testing": "^10.3.8",
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.7.5",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/jsdom": "^28.0.3",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.14.2",
        "@types/nodemailer": "^6.4.15",
        "@types/passport-google-oauth20": "^2.0.14",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/qrcode": "^1.5.5",
        "@types/uuid": "^9.0.8",
        "@typescript-eslint/eslint-plugin": "^7.11.0",
        "@typescript-eslint/parser": "^7.11.0",
        "dotenv": "^16.4.5",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-security": "^3.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.4.1",
        "prisma": "^5.14.0",
        "supertest": "^7.0.0",
        "ts-jest": "^29.1.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.4.5"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
